# =========================================================

# 🌿 LGC Articulate — DevLang Environment Configuration

# =========================================================

# This file defines environment variables required to run

# the backend locally.

#

# ❗ IMPORTANT:

# - Do NOT commit real secrets here

# - Replace placeholder values before running

# =========================================================

# =========================================================

# 🖥️ SERVER CONFIGURATION

# =========================================================

# Port where backend server runs

PORT=3000

# Environment mode (development | production)

NODE_ENV=development

# =========================================================

# 🗄️ DATABASE CONFIGURATION

# =========================================================

# MongoDB connection string

# Example (local): mongodb://localhost:27017/lgc-articulate-devlang

# Example (cloud): mongodb+srv://<user>:<pass>@cluster.mongodb.net/db

MONGO_URI=your_mongodb_connection_string

# =========================================================

# 🌐 API CONFIGURATION

# =========================================================

# Prefix for all API routes

API_PREFIX=/api

# =========================================================

# 🔐 CORS CONFIGURATION

# =========================================================

# Allowed frontend origin

# Example: http://localhost:5173 (for development)

CORS_ORIGIN=http://localhost:5173

# =========================================================

# 🚦 RATE LIMITING

# =========================================================

# Time window (in ms) for rate limiting

RATE_LIMIT_WINDOW_MS=900000

# Maximum number of requests per window

RATE_LIMIT_MAX_REQUESTS=100

# =========================================================

# 📊 LOGGING

# =========================================================

# Logging level (info | debug | error)

LOG_LEVEL=info

# =========================================================

# 🔒 AUTHENTICATION & SECURITY

# =========================================================

# Secret key for signing JWT tokens

JWT_SECRET=your_jwt_secret_key

# Token expiration time

# Examples: 1h, 24h, 7d

JWT_EXPIRATION=24h

# =========================================================

# 📧 EMAIL CONFIGURATION (BREVO)

# =========================================================

# API key for transactional emails

BREVO_API_KEY=your_brevo_api_key

# Sender email address

EMAIL_FROM=[your_email@example.com](mailto:your_email@example.com)

# Base domain for email links (used in verification/reset)

PRODUCTION_DOMAIN=http://localhost:3000

# =========================================================

# ⚙️ FEATURE FLAGS

# =========================================================

# Enable analytics tracking

ENABLE_ANALYTICS=true

# Enable public test endpoints (useful for development)

ENABLE_TEST_ENDPOINT=true

# =========================================================

# 🤖 AI PROVIDER KEYS (OPENROUTER)

# =========================================================

# Multiple keys used for fallback/retry strategy

OPENROUTER_API_KEY_ONE=your_openrouter_key_1
OPENROUTER_API_KEY_TWO=your_openrouter_key_2
OPENROUTER_API_KEY_THREE=your_openrouter_key_3
OPENROUTER_API_KEY_FOUR=your_openrouter_key_4

# =========================================================

# 🤖 AI PROVIDER KEYS (GEMINI)

# =========================================================

# Used as alternative provider in fallback chain

GEMINI_API_KEY_ONE=your_gemini_key_1
GEMINI_API_KEY_TWO=your_gemini_key_2
GEMINI_API_KEY_THREE=your_gemini_key_3
GEMINI_API_KEY_FOUR=your_gemini_key_4

# =========================================================

# 🤖 AI EXECUTION CONFIGURATION

# =========================================================

# Controls generation behavior

# Sampling temperature (lower = more deterministic)

AI_TEMPERATURE=0.4

# Maximum tokens per response

AI_MAX_TOKENS=300

# Timeout for AI response (in milliseconds)

AI_TIMEOUT=25000

# =========================================================

# 🧠 AI MODEL PRIORITY (FALLBACK ORDER)

# =========================================================

# Models are attempted in sequence based on availability

AI_MODEL_ONE=meta-llama/llama-3.3-70b-instruct:free
AI_MODEL_TWO=nousresearch/hermes-3-llama-3.1-405b:free
AI_MODEL_THREE=z-ai/glm-4.5-air:free
AI_MODEL_FOUR=openai/gpt-oss-120b:free
AI_MODEL_FIVE=openai/gpt-oss-20b:free
AI_MODEL_SIX=nvidia/nemotron-nano-9b-v2:free

# =========================================================

# 📝 NOTES

# =========================================================

# - Replace ALL "your_*" values before running the server

# - Keep real secrets only in `.env` (never commit them)

# - This file is safe to commit to GitHub

# =========================================================
