{
  "info": {
    "name": "LGC Articulate - DevLang API",
    "description": "Postman collection for current API routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "attemptId",
      "value": "",
      "type": "string"
    },
    {
      "key": "verifyToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "resetToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ""
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alex\",\n  \"email\": \"alex@example.com\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "signup"
              ]
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify?token={{verifyToken}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "verify"
              ],
              "query": [
                {
                  "key": "token",
                  "value": "{{verifyToken}}"
                }
              ]
            }
          }
        },
        {
          "name": "Resend Verification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alex@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/resend-verification",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "resend-verification"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data && data.token) {",
                  "    pm.collectionVariables.set('token', data.token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alex@example.com\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alex@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/forgot-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "forgot-password"
              ]
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"NewStrongPass456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "reset-password"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Evaluate",
      "item": [
        {
          "name": "Evaluate (Protected)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data && data.attemptId) {",
                  "    pm.collectionVariables.set('attemptId', data.attemptId);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"context\": \"Manager: \\\"Can you send the rollout plan by Friday?\\\"\",\n  \"speakerRole\": \"Engineer\",\n  \"listenerRole\": \"Manager\",\n  \"listenerQuestion\": \"Can you send the rollout plan by Friday?\",\n  \"userResponse\": \"I will send the rollout plan by Friday 4 PM and confirm risk checks before sharing.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/evaluate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "evaluate"
              ]
            }
          }
        },
        {
          "name": "Evaluate Test (Public)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"context\": \"Team lead asks for status update\",\n  \"speakerRole\": \"Developer\",\n  \"listenerRole\": \"Team Lead\",\n  \"listenerQuestion\": \"Where do we stand?\",\n  \"userResponse\": \"I completed the core changes and will finish tests by 3 PM.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/evaluate/test",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "evaluate",
                "test"
              ]
            }
          }
        },
        {
          "name": "Get History (Protected)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/evaluate/user/history?page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "evaluate",
                "user",
                "history"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Analytics (Protected)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/evaluate/analytics?timeframe=week",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "evaluate",
                "analytics"
              ],
              "query": [
                {
                  "key": "timeframe",
                  "value": "week"
                }
              ]
            }
          }
        },
        {
          "name": "Get Attempt By Id (Protected)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/evaluate/{{attemptId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "evaluate",
                "{{attemptId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Doubt",
      "item": [
        {
          "name": "Doubt Coaching",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"context\": \"Client asks why timeline shifted\",\n  \"speakerRole\": \"Project Manager\",\n  \"listenerRole\": \"Client\",\n  \"listenerQuestion\": \"Why did the date move?\",\n  \"userResponse\": \"We had some issues and it got delayed.\",\n  \"level\": \"average\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/doubt",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "doubt"
              ]
            }
          }
        }
      ]
    }
  ]
}
